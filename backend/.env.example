PORT=5000
NODE_ENV=development

# For local dev, point at local MySQL. For Vercel deployment, use your
# external managed MySQL provider's connection details (e.g. PlanetScale, Railway, Aiven).
DB_HOST=localhost
DB_PORT=3306
DB_USER=root
DB_PASSWORD=
DB_NAME=technow_mobile

# Generate a secure secret key with: openssl rand -base64 48
JWT_SECRET=your_jwt_secret_key_here_change_in_production
JWT_EXPIRES_IN=7d

USDT_WALLET_ADDRESS=your_trc20_wallet_address_here
EXCHANGE_RATE_API_URL=https://api.coingecko.com/api/v3/simple/price?ids=tether&vs_currencies=usd
CURRENCY_RATE_API_URL=https://api.exchangerate-api.com/v4/latest/USD

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=noreply@technowmobile.com

STOREFRONT_URL=http://localhost:5173
ADMIN_URL=http://localhost:5174

RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

CRON_SECRET=
